{
  "name": "@sidpro/validators",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "node --import tsx --test src/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sidpro/config": "workspace:*",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
