# SIDPRO Environment Configuration
# Copy to .env and adjust values for your environment

# Application
NODE_ENV=development
APP_NAME=SIDPRO
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://sidpro:sidpro_secret@localhost:5432/sidpro?schema=public
POSTGRES_USER=sidpro
POSTGRES_PASSWORD=sidpro_secret
POSTGRES_DB=sidpro
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=sidpro
MINIO_ROOT_PASSWORD=sidpro_secret
MINIO_BUCKET=sidpro-files
MINIO_USE_SSL=false
# Optional public base URL for browser-accessible presigned links (no trailing slash)
# MINIO_PUBLIC_URL=http://localhost:9000

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_TENANT_CODE=demo-desa

# Worker
WORKER_PORT=4001

# Email notifications
# REDIS_URL is required for API enqueue + worker consume.
# SMTP_HOST enables SMTP delivery; leave unset to use console adapter fallback.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@desa.example.id

# Tenant (default single-tenant)
DEFAULT_TENANT_CODE=demo-desa

# Seed (optional — required for staging/production seed)
# SEED_ADMIN_EMAIL=admin@demo-desa.id
# SEED_ADMIN_PASSWORD=set-strong-password-for-staging

# Smoke test (staging only — do not commit)
# STAGING_ADMIN_EMAIL=admin@demo-desa.id
# STAGING_ADMIN_PASSWORD=same-as-seed-admin-password
# SMOKE_RUN_SEED=0
# SMOKE_SKIP_WEB=0

# Production hardening flags
# Swagger is enabled by default outside production unless set to false.
# In production, it is disabled unless explicitly set to true and protected by infrastructure.
ENABLE_SWAGGER=false
# Demo portal fallback is enabled by default outside production unless set to false.
# Keep false in production so sample data is never shown as real village data.
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false
# Default PDF mode is synchronous in the API. Keep false unless the API is changed to enqueue pdf-generation jobs and the worker path is tested end-to-end.
ENABLE_PDF_WORKER=false

# Production Docker Compose notes (copy to a server-local .env and replace secrets)
# DATABASE_URL=postgresql://sidpro:<strong-password>@postgres:5432/sidpro?schema=public
# REDIS_URL=redis://redis:6379
# MINIO_ENDPOINT=minio
# NGINX_HTTP_PORT=80
