# SIDPRO Environment Configuration
# Copy to .env and adjust values for your environment

# Application
NODE_ENV=development
APP_NAME=SIDPRO
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://sidpro:sidpro_secret@localhost:5432/sidpro?schema=public
POSTGRES_USER=sidpro
POSTGRES_PASSWORD=sidpro_secret
POSTGRES_DB=sidpro
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=sidpro
MINIO_ROOT_PASSWORD=sidpro_secret
MINIO_BUCKET=sidpro-files
MINIO_USE_SSL=false

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Worker
WORKER_PORT=4001

# Tenant (default single-tenant)
DEFAULT_TENANT_CODE=demo-desa
