{
  "name": "@sidpro/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sidpro/types": "workspace:*",
    "bullmq": "^5.79.2",
    "nodemailer": "^9.0.1",
    "@aws-sdk/client-s3": "^3.1071.0",
    "@prisma/client": "6.19.3",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@sidpro/config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6"
  }
}
