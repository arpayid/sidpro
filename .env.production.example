# SIDPRO production template. Copy to .env on the server and replace every value.
NODE_ENV=production
APP_URL=https://desa.example.id
API_URL=https://desa.example.id
API_PORT=4000
API_HOST=0.0.0.0
WEB_PORT=3000
HTTP_PORT=80

POSTGRES_USER=sidpro_prod
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=sidpro
DATABASE_URL=postgresql://sidpro_prod:replace-with-a-long-random-database-password@postgres:5432/sidpro?schema=public

REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-at-least-32-random-characters-for-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://desa.example.id

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=replace-with-minio-admin-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_BUCKET=sidpro-files
MINIO_USE_SSL=false

NEXT_PUBLIC_API_URL=https://desa.example.id
NEXT_PUBLIC_TENANT_CODE=demo-desa
DEFAULT_TENANT_CODE=demo-desa

ENABLE_SWAGGER=false
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false
# Default PDF mode is synchronous in the API. Keep false unless the API is changed to enqueue pdf-generation jobs and the worker path is tested end-to-end.
ENABLE_PDF_WORKER=false

# Required only when running seed in staging/production.
# SEED_ADMIN_EMAIL=admin@desa.example.id
# SEED_ADMIN_PASSWORD=replace-with-a-strong-temporary-password

# Optional SMTP adapter.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=replace-me
# SMTP_PASSWORD=replace-me
# SMTP_FROM=noreply@desa.example.id
