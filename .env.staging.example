NODE_ENV=production
APP_URL=https://staging.desa.example.id
API_URL=https://staging.desa.example.id
API_PORT=4000
API_HOST=0.0.0.0
HTTP_PORT=8080

POSTGRES_USER=sidpro_staging
POSTGRES_PASSWORD=replace-with-staging-db-password
POSTGRES_DB=sidpro_staging
DATABASE_URL=postgresql://sidpro_staging:replace-with-staging-db-password@postgres:5432/sidpro_staging?schema=public
REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-at-least-32-random-characters-for-staging
CORS_ORIGIN=https://staging.desa.example.id

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=replace-with-staging-minio-user
MINIO_ROOT_PASSWORD=replace-with-staging-minio-password
MINIO_BUCKET=sidpro-files
MINIO_USE_SSL=false

NEXT_PUBLIC_API_URL=https://staging.desa.example.id
NEXT_PUBLIC_TENANT_CODE=demo-desa
DEFAULT_TENANT_CODE=demo-desa
ENABLE_SWAGGER=false
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false
# Default PDF mode is synchronous in the API. Keep false unless the API is changed to enqueue pdf-generation jobs and the worker path is tested end-to-end.
ENABLE_PDF_WORKER=false

SEED_ADMIN_EMAIL=admin@demo-desa.id
SEED_ADMIN_PASSWORD=replace-with-strong-staging-admin-password
STAGING_ADMIN_EMAIL=admin@demo-desa.id
STAGING_ADMIN_PASSWORD=replace-with-strong-staging-admin-password
SMOKE_RUN_SEED=0
SMOKE_SKIP_WEB=0
