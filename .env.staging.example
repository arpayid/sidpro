# Template only. Set real values as Bunnyshell secrets; never commit a populated .env file.
NODE_ENV=production
APP_URL=https://web-staging.example.com
API_URL=https://api-staging.example.com
API_PORT=4000
API_HOST=0.0.0.0
HTTP_PORT=8080

POSTGRES_USER=sidpro_staging
POSTGRES_PASSWORD=replace-with-a-long-random-db-password
POSTGRES_DB=sidpro_staging
DATABASE_URL=postgresql://sidpro_staging:replace-with-a-long-random-db-password@postgres:5432/sidpro_staging?schema=public

REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@redis:6379

JWT_SECRET=replace-with-at-least-32-random-characters-for-staging
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://web-staging.example.com
WEB_ORIGIN=https://web-staging.example.com

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=replace-with-staging-minio-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_BUCKET=sidpro-files-staging
MINIO_USE_SSL=false

# Public Railway/Bunnyshell endpoint for the API. Include /api/v1.
NEXT_PUBLIC_API_URL=https://api-staging.example.com/api/v1
NEXT_PUBLIC_TENANT_CODE=demo-desa
DEFAULT_TENANT_CODE=demo-desa
ENABLE_SWAGGER=true
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false
ENABLE_PDF_WORKER=false

SEED_ADMIN_EMAIL=admin@demo-desa.id
SEED_ADMIN_PASSWORD=replace-with-strong-staging-admin-password
STAGING_ADMIN_EMAIL=admin@demo-desa.id
STAGING_ADMIN_PASSWORD=replace-with-strong-staging-admin-password
SMOKE_RUN_SEED=0
SMOKE_SKIP_WEB=0
